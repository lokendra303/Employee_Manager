generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SYSTEM_ADMIN
  ADMIN
  SUPERVISOR
  DISTRIBUTOR
  WORKER
}

enum OrganizationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum AccrualStatus {
  ACCRUED
  PAID
  VOIDED
}

enum PayoutRunStatus {
  OPEN
  CLOSED
  PAID
}

enum TransactionType {
  DISBURSEMENT
  ACCRUAL_CREDIT
  ADJUSTMENT
  REVERSAL
}

enum PaymentMethod {
  CASH
  UPI
  BANK
  OTHER
}

enum FundRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FUND_SENT
  RECEIVED
  DISPUTED
}

enum FundRequesterType {
  DISTRIBUTOR
  SUPERVISOR
}

enum WalletHolderType {
  DISTRIBUTOR
  SUPERVISOR
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  ADJUSTMENT
}

model Organization {
  id             Int                @id @default(autoincrement())
  name           String
  contactEmail   String?            @map("contact_email")
  contactPhone   String?            @map("contact_phone")
  status         OrganizationStatus @default(PENDING)
  approvedAt     DateTime?          @map("approved_at")
  approvedById   Int?               @map("approved_by_id")
  rejectedReason String?            @map("rejected_reason") @db.Text
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  users        User[]        @relation("OrganizationUsers")
  workers      Worker[]
  distributors Distributor[]
  fundRequests FundRequest[]
  wallets      Wallet[]
  approvedBy   User?         @relation("ApprovedOrganizations", fields: [approvedById], references: [id])

  @@map("organizations")
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  name           String
  role           UserRole
  organizationId Int?      @map("organization_id")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization            Organization?            @relation("OrganizationUsers", fields: [organizationId], references: [id])
  approvedOrganizations   Organization[]           @relation("ApprovedOrganizations")
  workerProfile           Worker?                  @relation("WorkerUser")
  distributorProfile      Distributor?             @relation("DistributorUser")
  supervisorAssignments   SupervisorAssignment[]   @relation("SupervisorUser")
  markedAttendance        AttendanceRecord[]       @relation("MarkedBy")
  auditLogs               AuditLog[]
  distributorTransactions DistributorTransaction[] @relation("CreatedBy")
  fundRequestsRequested   FundRequest[]            @relation("FundRequester")
  fundRequestsReviewed    FundRequest[]            @relation("FundReviewer")
  fundRequestsSent        FundRequest[]            @relation("FundSender")
  wallet                  Wallet?
  walletTransactions      WalletTransaction[]      @relation("WalletTransactionCreator")

  @@map("users")
}

model Distributor {
  id             Int      @id @default(autoincrement())
  organizationId Int      @map("organization_id")
  name           String
  contactPhone   String?  @map("contact_phone")
  contactEmail   String?  @map("contact_email")
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(12, 2)
  userId         Int?     @unique @map("user_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?                    @relation("DistributorUser", fields: [userId], references: [id])
  workers      Worker[]
  transactions DistributorTransaction[]
  fundRequests FundRequest[]
  wallet       Wallet?

  @@map("distributors")
}

model Worker {
  id                 Int          @id @default(autoincrement())
  organizationId     Int          @map("organization_id")
  name               String
  phone              String?
  dailyRate          Decimal      @map("daily_rate") @db.Decimal(12, 2)
  payoutIntervalDays Int          @default(7) @map("payout_interval_days")
  payCycleAnchor     DateTime     @map("pay_cycle_anchor") @db.Date
  distributorId      Int          @map("distributor_id")
  userId             Int?         @unique @map("user_id")
  status             WorkerStatus @default(ACTIVE)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  distributor           Distributor            @relation(fields: [distributorId], references: [id])
  user                  User?                  @relation("WorkerUser", fields: [userId], references: [id])
  attendance            AttendanceRecord[]
  accruals              PayAccrual[]
  payoutRuns            PayoutRun[]
  transactions          DistributorTransaction[]
  supervisorAssignments SupervisorAssignment[]
  walletTransactions    WalletTransaction[]

  @@map("workers")
}

model SupervisorAssignment {
  id           Int      @id @default(autoincrement())
  supervisorId Int      @map("supervisor_id")
  workerId     Int      @map("worker_id")
  createdAt    DateTime @default(now()) @map("created_at")

  supervisor User   @relation("SupervisorUser", fields: [supervisorId], references: [id], onDelete: Cascade)
  worker     Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([supervisorId, workerId])
  @@map("supervisor_assignments")
}

model AttendanceRecord {
  id             Int              @id @default(autoincrement())
  workerId       Int              @map("worker_id")
  workDate       DateTime         @map("work_date") @db.Date
  status         AttendanceStatus
  markedByUserId Int              @map("marked_by_user_id")
  markedAt       DateTime         @default(now()) @map("marked_at")
  note           String?          @db.Text
  isLocked       Boolean          @default(false) @map("is_locked")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  markedBy User   @relation("MarkedBy", fields: [markedByUserId], references: [id])

  @@unique([workerId, workDate])
  @@map("attendance_records")
}

model PayAccrual {
  id          Int           @id @default(autoincrement())
  workerId    Int           @map("worker_id")
  workDate    DateTime      @map("work_date") @db.Date
  amount      Decimal       @db.Decimal(12, 2)
  status      AccrualStatus @default(ACCRUED)
  payoutRunId Int?          @map("payout_run_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  worker    Worker     @relation(fields: [workerId], references: [id], onDelete: Cascade)
  payoutRun PayoutRun? @relation(fields: [payoutRunId], references: [id])

  @@unique([workerId, workDate])
  @@map("pay_accruals")
}

model PayoutRun {
  id          Int             @id @default(autoincrement())
  workerId    Int             @map("worker_id")
  periodStart DateTime        @map("period_start") @db.Date
  periodEnd   DateTime        @map("period_end") @db.Date
  totalAmount Decimal         @map("total_amount") @db.Decimal(12, 2)
  status      PayoutRunStatus @default(OPEN)
  closedAt    DateTime?       @map("closed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  worker       Worker                   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  accruals     PayAccrual[]
  transactions DistributorTransaction[]

  @@map("payout_runs")
}

model DistributorTransaction {
  id            Int             @id @default(autoincrement())
  distributorId Int             @map("distributor_id")
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  workerId      Int?            @map("worker_id")
  payoutRunId   Int?            @map("payout_run_id")
  paymentMethod PaymentMethod?  @map("payment_method")
  notes         String?         @db.Text
  createdById   Int             @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")

  distributor Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  worker      Worker?     @relation(fields: [workerId], references: [id])
  payoutRun   PayoutRun?  @relation(fields: [payoutRunId], references: [id])
  createdBy   User        @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("distributor_transactions")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  entityType String   @map("entity_type")
  entityId   Int      @map("entity_id")
  action     String
  oldValue   String?  @map("old_value") @db.Text
  newValue   String?  @map("new_value") @db.Text
  reason     String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model FundRequest {
  id                Int               @id @default(autoincrement())
  organizationId    Int               @map("organization_id")
  requesterType     FundRequesterType @map("requester_type")
  walletId          Int               @map("wallet_id")
  distributorId     Int?              @map("distributor_id")
  calculatedAmount  Decimal           @map("calculated_amount") @db.Decimal(12, 2)
  requestedAmount   Decimal           @map("requested_amount") @db.Decimal(12, 2)
  approvedAmount    Decimal?          @map("approved_amount") @db.Decimal(12, 2)
  status            FundRequestStatus @default(PENDING)
  breakdown         String            @db.Text
  notes             String?           @db.Text
  rejectReason      String?           @map("reject_reason") @db.Text
  requestedById     Int               @map("requested_by_id")
  reviewedById      Int?              @map("reviewed_by_id")
  reviewedAt        DateTime?         @map("reviewed_at")
  fundSentAt        DateTime?         @map("fund_sent_at")
  fundSentById      Int?              @map("fund_sent_by_id")
  sentPaymentMethod PaymentMethod?    @map("sent_payment_method")
  sentReference     String?           @map("sent_reference")
  sentNotes         String?           @map("sent_notes") @db.Text
  receivedAt        DateTime?         @map("received_at")
  disputeReason     String?           @map("dispute_reason") @db.Text
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  wallet       Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  distributor  Distributor? @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  requestedBy  User         @relation("FundRequester", fields: [requestedById], references: [id])
  reviewedBy   User?        @relation("FundReviewer", fields: [reviewedById], references: [id])
  fundSentBy   User?        @relation("FundSender", fields: [fundSentById], references: [id])

  @@map("fund_requests")
}

model Wallet {
  id             Int              @id @default(autoincrement())
  organizationId Int              @map("organization_id")
  userId         Int              @unique @map("user_id")
  holderType     WalletHolderType @map("holder_type")
  distributorId  Int?             @unique @map("distributor_id")
  openingBalance Decimal          @default(0) @map("opening_balance") @db.Decimal(12, 2)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  distributor  Distributor?        @relation(fields: [distributorId], references: [id])
  transactions WalletTransaction[]
  fundRequests FundRequest[]

  @@map("wallets")
}

model WalletTransaction {
  id            Int                   @id @default(autoincrement())
  walletId      Int                   @map("wallet_id")
  type          WalletTransactionType
  amount        Decimal               @db.Decimal(12, 2)
  fundRequestId Int?                  @map("fund_request_id")
  workerId      Int?                  @map("worker_id")
  paymentMethod PaymentMethod?        @map("payment_method")
  reference     String?
  notes         String?               @db.Text
  createdById   Int                   @map("created_by_id")
  createdAt     DateTime              @default(now()) @map("created_at")

  wallet    Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  worker    Worker? @relation(fields: [workerId], references: [id])
  createdBy User    @relation("WalletTransactionCreator", fields: [createdById], references: [id])

  @@map("wallet_transactions")
}
