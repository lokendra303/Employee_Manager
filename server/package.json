{
  "name": "attendance-manager-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate",
    "db:generate": "node scripts/prisma-with-env.js generate",
    "db:migrate": "node scripts/prisma-with-env.js migrate dev && node scripts/prisma-with-env.js generate",
    "db:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-db.ps1",
    "db:seed": "node prisma/seed.js",
    "db:push": "node scripts/prisma-with-env.js db push"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.5.0"
  }
}
